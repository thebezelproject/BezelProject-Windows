<!-- default.lay file for The Bezel Project Atari 2600 pack -->

<mamelayout version="2">

  <element name="a2600">
    <image file="Atari-2600.png" />
  </element>

  <view name="Atari 2600 System Artwork">
    <screen index="0">
      <bounds x="240" y="0" width="1440" height="1080" />
    </screen>
	
    <element ref="a2600">
      <bounds x="0" y="0" width="1920" height="1080" />
    </element>
  </view>

